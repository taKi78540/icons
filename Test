🌳 Updated Decision Tree — UML (PlantUML)

@startuml
title Decision Tree — Request vs Incident (with OPAL hierarchy)

start

:Equipment scanned;

if (Found in HAM?) then (Yes)
  :Get Owner OU;
  :Get Location Country;
else (No)
  :Use Visitor Entity;
  :Use Visitor Country;
endif

:Search SharePoint (Owner OU + Country);

if (Match found?) then (Yes)
  :Evaluate eligibility;
else (No)
  :Traverse OPAL hierarchy;
  repeat
    :Get Parent OU;
    :Search SharePoint (Parent OU + Country);
  repeat while (No match AND parent exists)

  if (Match found?) then (Yes)
    :Evaluate eligibility;
  else (No)
    :RequestAllowed = FALSE;
    -> Incident Flow;
    stop
  endif
endif

:Check catalogs supported = yes;

if (Yes) then
  :Check equipment type;
  if (HAM Workstation or HAM Mobile = yes?) then (Yes)
    :RequestAllowed = TRUE;
  else (No)
    :RequestAllowed = FALSE;
  endif
else (No)
  :RequestAllowed = FALSE;
endif

if (RequestAllowed = TRUE) then (Yes)
  :Request flow (create/update);
else (No)
  :Incident flow;
endif

stop
@enduml


