@startuml
title Return Backend Decision Flow — Full Logic with HAM / SharePoint / OPAL / PIRUS

start

:Equipment scanned;

if (Equipment found in HAM?) then (Yes)
  :Retrieve Owner OU from HAM;
  :Retrieve Location Country from HAM;
else (No)
  :Use Visitor Entity as fallback;
  :Use Visitor Country as fallback;
endif

:Search SharePoint eligibility list\nusing (Owner OU + Country);

if (Match found in SharePoint?) then (Yes)
else (No)
  :Traverse OPAL hierarchy;
  repeat
    :Get parent Owner OU;
    :Search SharePoint eligibility list\nusing (Parent OU + Country);
  repeat while (No match found and parent exists)

  if (Match found after OPAL traversal?) then (Yes)
  else (No)
    :RequestAllowed = FALSE;
    :Create Incident;
    :Fill Incident description\nwith all return details;
    stop
  endif
endif

if (catalogs supported = yes?) then (Yes)
  if (HAM Workstation = yes\nor HAM Mobile = yes\naccording to equipment type?) then (Yes)
    :RequestAllowed = TRUE;
  else (No)
    :RequestAllowed = FALSE;
  endif
else (No)
  :RequestAllowed = FALSE;
endif

if (RequestAllowed = FALSE?) then (Yes)
  :Create Incident;
  :Fill Incident description\nwith all return details;
  stop
else (No)
endif

:Retrieve HAM owner;
:Determine equipment type;
:Search open restitution RITMs\nfor HAM owner + equipment type;

if (Matching RITM found?) then (Yes)
  :Update existing Request/RITM\nwith return details;
  stop
else (No)
endif

:Query PIRUS for primary user;

if (PIRUS primary user = HAM owner?) then (Yes)
  :Create new blank Request;
  :Complete new Request with return details;
  stop
else (No)
  :Search open restitution RITMs\nfor PIRUS primary user + equipment type;

  if (Matching RITM found?) then (Yes)
    :Update existing Request/RITM\nwith return details;
    stop
  else (No)
    :Create new blank Request;
    :Complete new Request with return details;
    stop
  endif
endif

@enduml
