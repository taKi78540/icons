@startuml
title Return Hardware — Global Front + Backend Flow

legend right
|= Color |= Meaning |
|<#DDEEFF>| Visitor / Entry tablet |
|<#E8F5E9>| Technician front workflow |
|<#FFF4CC>| Validation / decision |
|<#EADCF8>| Signature |
|<#E0F7FA>| Backend identification |
|<#DFF0D8>| Backend request creation |
|<#FFF4CC>| Catalog check |
|<#EADCF8>| Traceability / existing request link |
|<#FCE4EC>| PV generation / SharePoint storage |
endlegend

start

partition "Visitor experience — Entry tablet" #DDEEFF {
  :Visitor arrives at Le Comptoir;
  :Visitor identifies himself on entry tablet;
  :Visitor selects **Return Hardware**;
  :Visit is created / updated;
  :Visit reason = Hardware return;
  :Visitor joins waiting queue;
}

partition "Technician experience — Return Hardware front workflow" #E8F5E9 {
  :Technician takes charge of visitor;
  :Open visitor file;
  :Start **Return Hardware process**;

  :Open barcode scan / manual entry step;

  repeat
    :Scan barcode / enter serial number;

    if (Equipment identified?) then (Yes)
      :Display equipment information;
      :Technician selects target stockroom;
    else (No)
      :Technician enters available equipment data manually;
      :Technician selects target stockroom;
    endif

    :Technician validates item;
    :Add equipment to return bucket;

  repeat while (Another equipment with barcode?) is (Yes)

  :Proceed to accessories step;

  if (Accessories returned?) then (Yes)
    repeat
      :Technician selects returned accessory;
      :Set quantity if more than one;
      :Accessory is automatically added to return bucket;
    repeat while (Another accessory?) is (Yes)
  else (No)
    :No accessories declared;
  endif

  :Technician clicks Next;
  :Proceed to Return Summary;

  :Display all returned elements;
  :Equipment with barcode;
  :Manual / non-HAM equipment;
  :Accessories with quantities;
  :Target stockroom per item;

  if (Technician validates summary?) then (Yes)
    :Proceed to signature step;
  else (No)
    :Technician goes back and updates bucket;
  endif
}

partition "Signature and front confirmation" #EADCF8 {
  :Choose signature method;

  if (Signature on technician screen?) then (Yes)
    :Visitor signs on technician screen;
  else (Signature on entry tablet)
    :Generate short signature code;
    :Visitor enters code on tablet;
    :Visitor signs on tablet;
    :Signature completion is sent back to technician screen;
  endif

  if (Signature completed?) then (Yes)
    :Technician validates final return;
    :Front process completed;
  else (No)
    :Return remains pending signature;
    stop
  endif
}

partition "Backend — Identification" #E0F7FA {
  :Returned item received;

  if (Item type = PC / Mac / Mobile?) then (Yes)

    if (Item identified in HAM?) then (Yes)
      :Retrieve equipment data from HAM;
      :Retrieve HAM owner as reference user;

    else (No)
      :Search item in PIRUS;

      if (Item identified in PIRUS?) then (Yes)
        :Retrieve equipment data from PIRUS;
        :Retrieve PIRUS primary user as reference user;
      else (No)
        :Technician enters available equipment data manually;
        :Retrieve declared owner as reference user if provided;
      endif
    endif

  else (No)
    :Accessory or non-HAM searchable item;
    :Use visitor as reference user;
  endif
}

partition "Backend — Request creation" #DFF0D8 {
  if (Item type = Accessory?) then (Yes)
    :Create dedicated ServiceNow Return Request;
    :Populate Request with accessory return data;

  else (No)
    if (Item identified in HAM?) then (Yes)
      :Create dedicated ServiceNow Return Request;
      :Populate Request with HAM equipment data;
    else (No)
      :Create dedicated ServiceNow Return Request;
      :Set "equipment not found in HAM" = true;
      :Populate Request with PIRUS or manual data;
    endif
  endif

  :Retrieve created Request reference;
  :Update generated SC Task;
  :Assignment group, technician, status;
}

partition "Backend — Traceability / existing request link" #EADCF8 {
  if (Reference user identified?) then (Yes)

    partition "Catalog check" #FFF4CC {
      :Check whether reference user is catalog-supported;

      if (Catalog-supported?) then (Yes)
        :Search open restitution RITM;
        :For reference user + returned item type;

        if (Matching RITM found?) then (Yes)
          :Add created Request reference;
          :To additional notes of existing RITM;
        else (No)
          :No existing restitution request found;
        endif

      else (No)
        :Reference user not catalog-supported;
        :No existing request link required;
      endif
    }

  else (No)
    :Reference user not identified;
    :No existing request link possible;
  endif
}

partition "Backend — PV generation and SharePoint storage" #FCE4EC {
  :Generate signed return proof / PV;
  :Attach returned equipment list;
  :Attach accessories and quantities;
  :Attach visitor / reference user;
  :Attach technician information;
  :Attach date/time and Le Comptoir location;
  :Generate PDF document;
  :Store signed PV in SharePoint;
}

stop

@enduml
